# Generated by krkn-ai-pipeline-poc
# PoC for krkn-chaos/krkn-ai#188 — 5-stage pluggable discovery pipeline

# === Cluster Inventory ===
kubeconfig_file_path: "{{ kubeconfig_path }}"
namespaces:
{% for ns in components.namespaces %}  - {{ ns }}
{% endfor %}
# Discovered: {{ components.pods|length }} pods, {{ components.services|length }} services, {{ components.pvcs|length }} PVCs

# === Fitness Function ===
fitness_function:
  query: "{{ fitness_query }}"
{% if fitness_reason %}  # reason: {{ fitness_reason }}
{% endif %}

# === Health Checks ===
{% if health_checks %}health_checks:
{% for hc in health_checks %}  - name: {{ hc.name }}
    url: "{{ hc.url }}"
{% endfor %}{% else %}# health_checks: []   # no reachable endpoints discovered
{% endif %}

# === Scenarios ===
scenario:
{% for rec in scenario_recommendations %}  {{ rec.scenario_key }}:
    enable: {{ rec.enabled | lower }}
    # reason: {{ rec.reason }}
{% endfor %}
